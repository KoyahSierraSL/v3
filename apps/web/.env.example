# =============================================================================
# Vite loads env files from THIS directory (apps/web/), not the monorepo root.
# Copy to `.env` or `.env.local` here. `.env.local` overrides `.env` and is
# gitignored — prefer it for machine-specific values.
# =============================================================================

# -----------------------------------------------------------------------------
# Option A — Local Supabase (`pnpm db:start` from repo root, Docker required)
# -----------------------------------------------------------------------------
# After `pnpm db:start`, run `pnpm db:status` (or `pnpm exec supabase status`)
# and copy the API URL and anon key from the output into the variables below.
#
# Default local API URL (if you use standard ports):
# VITE_SUPABASE_URL=http://127.0.0.1:54321
#
# Default local anon key (JWT for supabase demo — same for all local CLI stacks):
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# -----------------------------------------------------------------------------
# Option B — Hosted Supabase (production / preview)
# -----------------------------------------------------------------------------
# Create the project in **eu-central-1** (Frankfurt) for GDPR alignment (KOY-211).
# Dashboard → Project Settings → API — use Project URL and anon (public) key only.
# Never put the service_role key in any VITE_* variable (it is bundled to the browser).
#
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=
