# Copy to ".env" and fill in values from your Supabase project:
# Dashboard → Project Settings → API
#
# Use the Project URL and the anon (public) key only.
# Never add the service_role key to Vite — any VITE_* variable is bundled into
# the browser and visible to anyone. Server-only secrets belong in a backend
# or Edge Function, not in this React app.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
