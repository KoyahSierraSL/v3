# =============================================================================
# Monorepo root — Turbo may pass through server-side env at build time (see
# turbo.json). The React app does NOT read files from here.
#
# For Supabase + Vite: copy and edit ONLY:
#   apps/web/.env.example  →  apps/web/.env  or  apps/web/.env.local
#
# See README.md → Supabase for local stack and hosted (eu-central-1) setup.
# =============================================================================

# Example (optional, for CI or tooling that runs from root — not used by Vite):
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
